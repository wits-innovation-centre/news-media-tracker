{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "news-media-tracker",
  "compatibility_date": "2026-07-10",
  "compatibility_flags": ["nodejs_compat"],
  "build": {
    "command": "pnpm run build",
  },
  "assets": {
    "directory": "dist",
    "not_found_handling": "single-page-application",
  },
  "observability": {
    "enabled": true,
  },
}
