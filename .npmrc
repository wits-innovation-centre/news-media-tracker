# pnpm monorepo shared-store policy
# ─────────────────────────────────────────────────────────────────────────────
# Explicit content-addressable store path. Using the XDG data dir avoids
# root-owned store paths that cause ERR_PNPM_EACCES in Docker/devcontainer.
store-dir=~/.local/share/pnpm/store/v3

# Copy packages from the store instead of hard-linking. Hard-links fail when
# the store and project root are on different filesystems (e.g., bind mounts
# inside Docker volumes or devcontainer workspace mounts).
package-import-method=copy

# Hoist all packages to node_modules so tools that traverse node_modules
# directly (webpack, ts-node, electron-builder) keep working without changes.
node-linker=hoisted

# Automatically install declared peer dependencies so devDependency ranges
# resolve without --legacy-peer-deps workarounds.
auto-install-peers=true

# Single lockfile at the workspace root. Keeps the dependency graph
# deterministic across parallel agent runs and CI jobs.
shared-workspace-lockfile=true
