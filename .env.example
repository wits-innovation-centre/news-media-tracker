# External Server Stack – Environment Variables
#
# Copy this file to .env, then fill in the values you need.
# Usage:
#   cp .env.example .env
#   # edit .env
#   docker compose --profile external-server up -d

# ── sqld (LibSQL server) ──────────────────────────────────────────────────────

# JWT signing key used by the sqld server to verify bearer tokens.
# ⚠️  Leave empty ONLY for local development or private, firewalled networks.
#     Always set before exposing sqld on a public network.
# Generate a key with:  openssl rand -base64 32
SQLD_AUTH_JWT_KEY=

# Bearer token the tracker app sends when connecting to sqld as a remote.
# Must be a valid JWT accepted by the target sqld auth verifier.
# The token algorithm depends on your sqld deployment/auth configuration.
# See README "Generating auth credentials" for a step-by-step guide.
# Leave empty when auth is disabled.
DATABASE_AUTH_TOKEN=

# Host port for the sqld HTTP endpoint (default: 8080).
SQLD_HTTP_PORT=8080

# ── tracker-app (Next.js web server) ─────────────────────────────────────────

# Host port for the tracker web UI (default: 3000).
APP_PORT=3000

# Public base URL for the tracker app (used by PWA and internal API calls).
# Change to your domain or IP when deploying on a server.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# ── local-server profile (container-local runtime) ───────────────────────────

# Host port for the container-local tracker app service.
LOCAL_SERVER_PORT=3001

# Base URL advertised by the local-server service.
LOCAL_SERVER_BASE_URL=http://localhost:3001
