{
    "name": "news-media-tracker",
    "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
    "workspaceFolder": "/workspaces/Homicide-Media-Tracker",
    "forwardPorts": [
        3000,
        3001,
        8080
    ],
    "portsAttributes": {
        "3000": {
            "label": "Next.js Dev Server"
        },
        "3001": {
            "label": "Electron Dev"
        },
        "8080": {
            "label": "sqld Sync Target (external-server profile)"
        }
    },
    "postCreateCommand": "npm install --legacy-peer-deps",
    "remoteUser": "node"
}
